\newlabel{fig:pca_cumvar}{{12}{23}{Tầng 3 -- Giảm chiều: PCA cumulative explained variance. Đường ngang tại 95\% và 99\% cho thấy số thành phần cần thiết. Tập tabular này yêu cầu số PC lớn để giải thích 95\% phương sai, phản ánh tính đa chiều cao của đặc trưng V-Vesta}{figure.caption.29}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces t-SNE 2D ($n=3000$ mẫu, perplexity=30) trên tập đặc trưng đã chọn, tô màu theo nhãn isFraud. Sự xen lẫn giữa hai lớp xác nhận bài toán fraud detection là phi tuyến và khó phân tách trong không gian nguyên bản.}}{24}{figure.caption.30}\protected@file@percent }
\newlabel{fig:tsne_tabular}{{13}{24}{t-SNE 2D ($n=3000$ mẫu, perplexity=30) trên tập đặc trưng đã chọn, tô màu theo nhãn isFraud. Sự xen lẫn giữa hai lớp xác nhận bài toán fraud detection là phi tuyến và khó phân tách trong không gian nguyên bản}{figure.caption.30}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces UMAP 2D ($n\_neighbors=15$, $min\_dist=0{,}1$) trên 32 đặc trưng được chọn. So với t-SNE, UMAP bảo toàn cấu trúc toàn cục tốt hơn và nhanh hơn ($\approx 3\times $). Sự xen lẫn hai lớp tương tự t-SNE -- xác nhận rằng fraud detection yêu cầu mô hình phi tuyến phức tạp, không đơn thuần là vấn đề đặc trưng.}}{24}{figure.caption.31}\protected@file@percent }
\newlabel{fig:umap_tabular}{{14}{24}{UMAP 2D ($n\_neighbors=15$, $min\_dist=0{,}1$) trên 32 đặc trưng được chọn. So với t-SNE, UMAP bảo toàn cấu trúc toàn cục tốt hơn và nhanh hơn ($\approx 3\times $). Sự xen lẫn hai lớp tương tự t-SNE -- xác nhận rằng fraud detection yêu cầu mô hình phi tuyến phức tạp, không đơn thuần là vấn đề đặc trưng}{figure.caption.31}{}}
